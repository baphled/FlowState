{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "skipDangerousModePermissionPrompt": true,
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Agent",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "TaskStop",
      "TaskOutput",
      "ScheduleWakeup",
      "ToolSearch"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(git push)",
      "Bash(git commit -m *)",
      "Bash(git commit -m)",
      "Bash(git commit -am *)",
      "Bash(git commit -am)",
      "Bash(git commit --amend *)",
      "Bash(git commit --amend)",
      "Bash(git commit --no-verify *)",
      "Bash(git commit --no-verify)",
      "Bash(git commit -F *)",
      "Bash(sudo *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)"
    ]
  }
}
