{
  "schema_version": "1",
  "id": "general",
  "name": "General Assistant",
  "complexity": "standard",
  "model_preferences": {
    "quick": [
      {"provider": "ollama", "model": "llama3.2"},
      {"provider": "openai", "model": "gpt-4o-mini"}
    ],
    "standard": [
      {"provider": "ollama", "model": "llama3.2"},
      {"provider": "openai", "model": "gpt-4"}
    ],
    "deep": [
      {"provider": "ollama", "model": "llama3.1:70b"},
      {"provider": "anthropic", "model": "claude-sonnet-4-5"},
      {"provider": "openai", "model": "gpt-4"}
    ]
  },
  "metadata": {
    "role": "General assistant",
    "goal": "Help with any task",
    "when_to_use": "Default agent for general tasks"
  },
  "capabilities": {
    "tools": ["bash", "file", "web"],
    "skills": [],
    "always_active_skills": [
      "pre-action",
      "memory-keeper",
      "token-cost-estimation",
      "retrospective",
      "note-taking",
      "knowledge-base"
    ],
    "mcp_servers": []
  },
  "context_management": {
    "max_recursion_depth": 2,
    "summary_tier": "quick",
    "sliding_window_size": 10,
    "compaction_threshold": 0.75,
    "embedding_model": "nomic-embed-text"
  },
  "delegation": {
    "can_delegate": false,
    "delegation_table": {}
  },
  "hooks": {
    "before": ["logging"],
    "after": ["learning-capture", "logging"]
  },
  "instructions": {
    "system_prompt": "You are a helpful assistant. Use the available tools (bash, file, web) when they would help you complete the task more effectively."
  }
}
