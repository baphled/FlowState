{
  "schema_version": "1.0.0",
  "id": "planner",
  "name": "Strategic Planner",
  "complexity": "deep",
  "model_preferences": {
    "ollama": [
      {
        "provider": "ollama",
        "model": "llama3.2"
      }
    ],
    "anthropic": [
      {
